# =============================================================================
# MedScribe AI - Variables de Entorno
# =============================================================================
# Copia este archivo a .env y llena los valores.
# Para correr con Docker: docker compose up --build
# =============================================================================

# ----------------------------------------------------------------------------
# SQL Server (usado por docker-compose)
# ----------------------------------------------------------------------------
# Password para el usuario sa del contenedor SQL Server.
# Minimo 8 caracteres, con mayusculas, minusculas, numeros y simbolos.
SA_PASSWORD=MedScribe2026!

# ----------------------------------------------------------------------------
# Puertos expuestos en tu maquina (host)
# Si ya tienes algo corriendo en estos puertos, cambialos aqui.
# ----------------------------------------------------------------------------
GATEWAY_PORT=5000
AI_SERVICE_PORT=8000
# SQL Server del contenedor. Por defecto 1434 para NO chocar con un SQL Server
# local (que usa 1433). Desde SSMS conectar a: localhost,1434
SQL_HOST_PORT=1434

# ----------------------------------------------------------------------------
# Deepgram - Diarizacion cloud (opcional)
# Registrarse en https://deepgram.com ($200 credito gratis)
# ----------------------------------------------------------------------------
DEEPGRAM_API_KEY=

# ----------------------------------------------------------------------------
# Agente de Voz
# ----------------------------------------------------------------------------
AGENTE_VOZ=

# ----------------------------------------------------------------------------
# IA Principal - Groq (OBLIGATORIO para transcripcion + LLM)
# Registrarse en https://console.groq.com
# ----------------------------------------------------------------------------
AI_PROVIDER=groq
AI_API_KEY=
AI_MODEL=llama-3.3-70b-versatile
AI_BASE_URL=https://api.groq.com/openai/v1

# ----------------------------------------------------------------------------
# IA Fallback - SambaNova (opcional)
# ----------------------------------------------------------------------------
AI_FALLBACK_PROVIDER=
AI_FALLBACK_API_KEY=
AI_FALLBACK_MODEL=
AI_FALLBACK_BASE_URL=

# ----------------------------------------------------------------------------
# IA Extras (opcionales)
# ----------------------------------------------------------------------------
AI_EXTRA_1_ID=
AI_EXTRA_1_PROVIDER=
AI_EXTRA_1_API_KEY=
AI_EXTRA_1_MODEL=
AI_EXTRA_1_BASE_URL=

AI_EXTRA_2_ID=
AI_EXTRA_2_PROVIDER=
AI_EXTRA_2_API_KEY=
AI_EXTRA_2_MODEL=
AI_EXTRA_2_BASE_URL=

AI_EXTRA_3_ID=
AI_EXTRA_3_PROVIDER=
AI_EXTRA_3_API_KEY=
AI_EXTRA_3_MODEL=
AI_EXTRA_3_BASE_URL=

AI_EXTRA_4_ID=
AI_EXTRA_4_PROVIDER=
AI_EXTRA_4_API_KEY=
AI_EXTRA_4_MODEL=
AI_EXTRA_4_BASE_URL=

# HuggingFace token para Pyannote (diarizacion local)
AI_EXTRA_5_ID=huggingface
AI_EXTRA_5_PROVIDER=huggingface
AI_EXTRA_5_API_KEY=
AI_EXTRA_5_MODEL=pyannote/speaker-diarization-3.1
AI_EXTRA_5_BASE_URL=

AI_EXTRA_6_ID=
AI_EXTRA_6_PROVIDER=
AI_EXTRA_6_API_KEY=
AI_EXTRA_6_MODEL=
AI_EXTRA_6_BASE_URL=

AI_EXTRA_7_ID=
AI_EXTRA_7_PROVIDER=
AI_EXTRA_7_API_KEY=
AI_EXTRA_7_MODEL=
AI_EXTRA_7_BASE_URL=

# ----------------------------------------------------------------------------
# Benchmark Config
# ----------------------------------------------------------------------------
BENCHMARK_ROUNDS=
