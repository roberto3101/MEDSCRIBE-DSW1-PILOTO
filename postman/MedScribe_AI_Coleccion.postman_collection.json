{
	"info": {
		"_postman_id": "medscribe-col-001",
		"name": "MedScribe AI - API Completa",
		"description": "Coleccion completa de endpoints para MedScribe AI.\nGateway C# (:5000) + Servicio IA Python (:8000)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "01. Autenticacion",
			"item": [
				{
					"name": "Iniciar Sesion (Admin)",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"correoElectronico\": \"{{correo_admin}}\",\n\t\"contrasena\": \"{{password_admin}}\"\n}"
						},
						"url": {
							"raw": "{{gateway_url}}/api/autenticacion/iniciar-sesion",
							"host": ["{{gateway_url}}"],
							"path": ["api", "autenticacion", "iniciar-sesion"]
						}
					}
				},
				{
					"name": "Iniciar Sesion (Medico)",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"}
